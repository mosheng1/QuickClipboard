    "lint": "eslint . --ext .js,.jsx"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^26.1.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1"
  }
}
