    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.6",
    "unocss": "^66.5.4",
    "vite": "^7.0.4",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^4.1.7"
  },
