{
  "name": "quickclipboard",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:no-watch": "tauri dev --no-watch",
    "tauri:dev:community": "node scripts/community-build.js --dev",
    "tauri:build": "tauri build",
    "tauri:build:community": "node scripts/community-build.js --community",
    "prepare": "husky",
    "test": "cd src-tauri/plugins/screenshot-suite-oss/web && vitest run",
    "test:watch": "cd src-tauri/plugins/screenshot-suite-oss/web && vitest",
    "test:e2e": "cd src-tauri/plugins/screenshot-suite-oss/web && playwright test",
    "test:main": "vitest run",
    "test:main:watch": "vitest"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix --ext .js,.jsx"
    ],
    "src-tauri/plugins/screenshot-suite-oss/web/**/*.{js,jsx}": [
      "eslint --fix --ext .js,.jsx",
      "vitest related --run --config src-tauri/plugins/screenshot-suite-oss/web/vitest.config.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
